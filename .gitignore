# Terraform state files (VERY IMPORTANT - contains secrets)
*.tfstate
*.tfstate.*

# Terraform directory
.terraform/

# Terraform lock file (optional: keep or ignore)
# .terraform.lock.hcl

# Sensitive variable files
*.tfvars
*.tfvars.json

# Crash logs
crash.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config
.terraformrc
terraform.rc

# SSH keys (VERY IMPORTANT)
*.pem

# OS files
.DS_Store
Thumbs.db